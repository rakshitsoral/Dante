// CRITICAL: This must be the FIRST script in <head> to prevent flash
(function() {
    'use strict';
    
    // Immediately apply saved theme to prevent flash
    const savedTheme = localStorage.getItem('site-theme');
    
    // Apply theme to HTML element immediately (blocking, before render)
    if (savedTheme === 'light') {
        document.documentElement.classList.add('light-mode');
    }
    
    // Prevent multiple initializations
    if (window.__themeManagerActive) return;
    window.__themeManagerActive = true;
    
    // Function to sync theme to body element
    function syncTheme() {
        const isLight = document.documentElement.classList.contains('light-mode');
        
        if (document.body) {
            if (isLight) {
                document.body.classList.add('light-mode');
            } else {
                document.body.classList.remove('light-mode');
            }
        }
        
        updateIcons();
    }
    
    // Function to update button icons
    function updateIcons() {
        const sunIcon = document.getElementById('sun-icon');
        const moonIcon = document.getElementById('moon-icon');
        
        if (!sunIcon || !moonIcon) return;
        
        const isLight = document.documentElement.classList.contains('light-mode') || 
                        document.body.classList.contains('light-mode');
        
        if (isLight) {
            sunIcon.classList.add('hidden');
            moonIcon.classList.remove('hidden');
        } else {
            sunIcon.classList.remove('hidden');
            moonIcon.classList.add('hidden');
        }
    }
    
    // Function to toggle theme
    function toggleTheme() {
        const isLight = document.body.classList.contains('light-mode');
        
        if (isLight) {
            // Turn OFF light mode
            document.documentElement.classList.remove('light-mode');
            document.body.classList.remove('light-mode');
            localStorage.setItem('site-theme', 'dark');
        } else {
            // Turn ON light mode
            document.documentElement.classList.add('light-mode');
            document.body.classList.add('light-mode');
            localStorage.setItem('site-theme', 'light');
        }
        
        updateIcons();
    }
    
    // Initialize when DOM is ready
    function init() {
        // Sync theme when body becomes available
        syncTheme();
        
        // Set up global click handler using event delegation with capture phase
        document.addEventListener('click', function(e) {
            const button = e.target.closest('#theme-toggle');
            
            if (button) {
                e.preventDefault();
                e.stopPropagation();
                toggleTheme();
                return false;
            }
        }, true); // Use capture phase to catch before any other handlers
        
        // Watch for DOM changes to re-sync when button is added (for SPA navigation)
        const observer = new MutationObserver(function(mutations) {
            for (let mutation of mutations) {
                if (mutation.addedNodes.length > 0) {
                    // Check if theme toggle button was added
                    for (let node of mutation.addedNodes) {
                        if (node.nodeType === 1) { // Element node
                            const hasToggle = node.id === 'theme-toggle' || 
                                            node.querySelector && node.querySelector('#theme-toggle');
                            if (hasToggle) {
                                syncTheme();
                                return;
                            }
                        }
                    }
                }
            }
        });
        
        observer.observe(document.documentElement, {
            childList: true,
            subtree: true
        });
    }
    
    // Run init when DOM is ready
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
    } else {
        // DOM already loaded
        init();
    }
    
    // Also sync on pageshow (handles back/forward cache)
    window.addEventListener('pageshow', function() {
        syncTheme();
    });
    
})();
    </script>

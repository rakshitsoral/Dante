   <!-- Back to Top Button -->
<button id="backToTop"
  style="
    position: fixed;
    bottom: 5.5rem;
    right: 1.5rem;
    width: 48px;
    height: 48px;
    border-radius: 9999px;
    border: none;
    background: #2563eb;
    color: white;
    font-size: 20px;
    cursor: pointer;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease, transform 0.3s ease;
    z-index: 1000;
  "
  aria-label="Back to top">
  ↑
</button>

<script>
  (function () {
    const btn = document.getElementById("backToTop");

    window.addEventListener("scroll", function () {
      if (window.scrollY > 300) {
        btn.style.opacity = "1";
        btn.style.pointerEvents = "auto";
        btn.style.transform = "translateY(0)";
      } else {
        btn.style.opacity = "0";
        btn.style.pointerEvents = "none";
        btn.style.transform = "translateY(10px)";
      }
    });

    btn.addEventListener("click", function () {
      window.scrollTo({
        top: 0,
        behavior: "smooth"
      });
    });
  })();
</script>

<!-- WhatsApp Chatbot Widget -->
<div class="wa-widget" id="whatsapp-chatbot-widget">
  <!-- Chat Container -->
  <div class="wa-chat-container" id="waChatContainer" aria-hidden="true">
    <!-- Header -->
    <div class="wa-header">
      <div class="wa-avatar-container">
        <img src="/assets/img/home/Rakshit Soral.jpg" alt="Rakshit Soral avatar" class="wa-avatar">
        <span class="wa-online-dot"></span>
      </div>
      <div class="wa-header-info">
        <h4 class="wa-header-name">Rakshit Soral</h4>
        <p class="wa-header-status">Typically replies in a few minutes</p>
      </div>
      <button class="wa-close-btn" id="waCloseBtn" aria-label="Close chat window">×</button>
    </div>
    
    <!-- Body -->
    <div class="wa-body" id="waChatBody">
      <div class="wa-message-bubble">
        Hey there! 👋 I'm Rakshit. How can I help you today?
        <span class="wa-message-time" id="waMsgTime">23:30</span>
      </div>
    </div>
    
    <!-- Footer / Input -->
    <form class="wa-footer" id="waChatForm">
      <div class="wa-input-container">
        <input type="text" class="wa-input" id="waInputMessage" placeholder="Type your message..." autocomplete="off">
      </div>
      <button type="submit" class="wa-send-btn" id="waSendBtn" aria-label="Send message to WhatsApp">
        <svg viewBox="0 0 24 24" xml:space="preserve">
          <path d="M2.01,21L23,12L2.01,3L2,10l15,2l-15,2L2.01,21z"/>
        </svg>
      </button>
    </form>
  </div>

  <!-- Launcher Button -->
  <button class="wa-launcher" id="waLauncher" aria-label="Open WhatsApp chat window">
    <svg viewBox="0 0 448 512">
      <path d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L3 508l146.2-38.3c32.5 17.7 68.9 27 106.3 27 122.4 0 222-99.6 222-222 0-59.3-23.2-115-65-156.9zM223.9 458.2c-33.1 0-65.7-8.9-94.2-25.7l-6.7-4-86.8 22.8 23.3-84.6-4.4-7c-18.5-29.4-28.2-63.3-28.2-98.2 0-101.7 82.8-184.5 184.6-184.5 49.3 0 95.6 19.2 130.4 54.1 34.8 34.9 56.2 81.2 56.1 130.5 0 101.8-84.9 184.6-186.6 184.6zm101.2-138.2c-5.5-2.8-32.8-16.2-37.9-18-5.1-1.9-8.8-2.8-12.5 2.8-3.7 5.6-14.3 18-17.6 21.8-3.2 3.7-6.5 4.2-12 1.4-32.6-16.3-54-29.1-75.5-66-5.7-9.8 5.7-9.1 16.3-30.3 1.8-3.7.9-6.9-.5-9.7-1.4-2.8-12.5-30.1-17.1-41.2-4.5-10.8-9.1-9.3-12.5-9.5-3.2-.2-6.9-.2-10.6-.2-3.7 0-9.7 1.4-14.8 6.9-5.1 5.6-19.4 19-19.4 46.3 0 27.3 19.9 53.7 22.6 57.4 2.8 3.7 39.1 59.7 94.8 83.8 35.2 15.2 49 16.5 66.6 13.9 10.7-1.6 32.8-13.4 37.4-26.4 4.6-13 4.6-24.1 3.2-26.4-1.3-2.5-5-3.9-10.5-6.6z"/>
    </svg>
    <span class="wa-badge" id="waBadge">1</span>
  </button>
</div>

<script>
  (function () {
    const launcher = document.getElementById("waLauncher");
    const container = document.getElementById("waChatContainer");
    const closeBtn = document.getElementById("waCloseBtn");
    const badge = document.getElementById("waBadge");
    const form = document.getElementById("waChatForm");
    const input = document.getElementById("waInputMessage");
    const msgTime = document.getElementById("waMsgTime");

    // Set message timestamp dynamically to current local time
    if (msgTime) {
      const now = new Date();
      const hours = String(now.getHours()).padStart(2, '0');
      const minutes = String(now.getMinutes()).padStart(2, '0');
      msgTime.textContent = `${hours}:${minutes}`;
    }

    // Toggle widget visibility
    function toggleChat(e) {
      if (e) {
        e.preventDefault();
        e.stopPropagation();
      }
      const isOpen = container.classList.contains("open");
      if (isOpen) {
        container.classList.remove("open");
        container.setAttribute("aria-hidden", "true");
      } else {
        container.classList.add("open");
        container.setAttribute("aria-hidden", "false");
        // Hide badge on first open
        if (badge) {
          badge.style.display = "none";
          localStorage.setItem("wa-badge-read", "true");
        }
        // Focus the input when chat window opens
        setTimeout(() => input.focus(), 150);
      }
    }

    // Check if user has already read the notification before
    if (localStorage.getItem("wa-badge-read") === "true" && badge) {
      badge.style.display = "none";
    }

    launcher.addEventListener("click", toggleChat);
    closeBtn.addEventListener("click", toggleChat);

    // Close on click outside
    document.addEventListener("click", function (e) {
      if (!container.contains(e.target) && !launcher.contains(e.target)) {
        if (container.classList.contains("open")) {
          container.classList.remove("open");
          container.setAttribute("aria-hidden", "true");
        }
      }
    });

    // Handle form submit (redirection)
    form.addEventListener("submit", function (e) {
      e.preventDefault();
      const message = input.value.trim();
      const phone = "919602542617";
      let url = `https://wa.me/${phone}`;
      
      if (message) {
        url += `?text=${encodeURIComponent(message)}`;
      } else {
        url += `?text=${encodeURIComponent("Hi Rakshit, I visited your website and wanted to connect!")}`;
      }
      
      window.open(url, "_blank");
      input.value = "";
    });
  })();
</script>


